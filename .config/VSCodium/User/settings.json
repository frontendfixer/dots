{
  "window.menuBarVisibility": "toggle",
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.activeIconPack": "react_redux",
  "material-icon-theme.files.color": "#f1fa8c",
  "material-icon-theme.folders.color": "#8be9fd",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.wrapTabs": true,
  "workbench.preferredDarkColorTheme": "Dracula Refined",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.colorCustomizations": {
    "statusBar.background": "#0e1316",
    "statusBar.foreground": "#f9f9ff",
    "statusBar.border": "#15181b",
    "statusBarItem.errorBackground": "#ff5e5e",
    "statusBarItem.errorForeground": "#212128",
    "statusBarItem.warningBackground": "#ff5e5e",
    "statusBarItem.warningForeground": "#212128",
    "statusBarItem.activeBackground": "#5fff87",
    "statusBarItem.hoverBackground": "#2c8ad6"
  },
  "editor.fontFamily": "'FiraCode Nerd Font','Hack Nerd Font'",
  "editor.fontWeight": "400",
  "editor.lineHeight": 24,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "smooth",
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.foldingStrategy": "indentation",
  "editor.guides.bracketPairs": "active",
  "editor.mouseWheelZoom": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.quickSuggestionsDelay": 0,
  "editor.renderWhitespace": "none",
  "explorer.confirmDelete": true,
  "explorer.autoReveal": true,
  "editor.suggest.preview": true,
  "editor.rename.enablePreview": false,
  "explorer.decorations.badges": false,
  "html.hover.references": false,
  "css.hover.references": false,
  "html.hover.documentation": false,
  "css.hover.documentation": false,
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.preferences": {
    "css.color.short": true
  },
  "emmet.triggerExpansionOnTab": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "path-intellisense.autoSlashAfterDirectory": true,
  "path-intellisense.autoTriggerNextSuggestion": true,
  "path-intellisense.showHiddenFiles": true,
  "path-intellisense.extensionOnImport": false,
  "path-intellisense.mappings": {
    "/": "${workspaceFolder}"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.paths": false,
  "javascript.suggest.paths": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "cSpell.userWords": [
    "aadhaar",
    "bootstarp",
    "bullmq",
    "clsx",
    "datatable",
    "daterangepicker",
    "firestore",
    "fontawesome",
    "fortawesome",
    "frontendfixer",
    "hookform",
    "imageurl",
    "Lakshmikanta",
    "lucide",
    "mysqldump",
    "NEXTAUTH",
    "nextui",
    "oklch",
    "oxfmt",
    "oxlint",
    "Patra",
    "rediss",
    "shadcn",
    "signin",
    "signup",
    "stylelint",
    "stylelintrc",
    "stylexjs",
    "Swal",
    "tailwindcss",
    "toastify",
    "usehooks",
    "WBSCSGS",
    "workos"
  ],
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "FiraCode Nerd Font",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.fontWeight": "300",
  "debug.console.acceptSuggestionOnEnter": "on",
  "security.workspace.trust.untrustedFiles": "open",
  "better-comments.highlightPlainText": true,
  "color-highlight.matchWords": true,
  "github.gitProtocol": "ssh",
  "tailwindCSS.emmetCompletions": true,
  "git.autofetch": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "git.ignoreRebaseWarning": true,
  "editor.linkedEditing": true,
  "explorer.confirmDragAndDrop": false,
  "git.confirmSync": false,
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "git.suggestSmartCommit": false,
  "files.associations": {
    "*.css": "tailwindcss",
    "*.scss": "scss"
  },
  "workbench.editor.highlightModifiedTabs": true,
  "editor.minimap.enabled": true,
  "git.openRepositoryInParentFolders": "always",
  "redhat.telemetry.enabled": false,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "workbench.startupEditor": "none",
  "diffEditor.ignoreTrimWhitespace": false,
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://turborepo.com": true,
    "https://ui.shadcn.com": true,
    "https://www.schemastore.org/": true
  },
  "workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "dotenv": true
  },
  "diffEditor.hideUnchangedRegions.enabled": true
}
